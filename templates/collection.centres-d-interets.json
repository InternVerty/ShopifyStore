e","text_type_scale":"small","icon_position":"above","mobile_stack":false,"section_height":"medium","color_scheme":"none","full_width":true,"dividers":"none","prevent_animation":false}},"custom_liquid_XUpbEa":{"type":"custom-liquid","custom_css":["p {text-align: justify;}"],"name":"Comité de lecture selec...","settings":{"custom_liquid":"<div class=\"container\">\n    <h2 class=\"h4\">Le comité de lecture Verty sélectionne les meilleurs livres pour enfants<\/h2>\n<p> Notre <strong>comité de lecture<\/strong>, composé d'institutrices, d'orthophonistes, de psychologues, de parents, tous\n      <strong>passionnés de littérature jeunesse<\/strong> et investis d’une mission essentielle : <strong>transmettre le goût de la lecture<\/strong> à tous les enfants\n      et mettre entre leurs mains des livres qui les aideront à se construire avec des <strong>repères solides<\/strong>. <\/p>\n    <p>\n      Le comité de lecture <strong>sélectionne avec soin<\/strong> les <strong>meilleurs livres pour enfants<\/strong> en s'appuyant sur plusieurs critères essentiels.\n      Nous privilégions des ouvrages <strong>écrits dans une belle langue<\/strong>, avec un <strong>style d'écriture de qualité<\/strong> et un <strong>vocabulaire riche<\/strong>,\n      afin de <strong>nourrir le développement intellectuel<\/strong> des jeunes lecteurs.\n    <\/p>\n    <p>\n      La <strong>qualité esthétique<\/strong> des illustrations et de la couverture est également prise en compte, car nous croyons en leur pouvoir\n      d’<strong>éveiller l'enfant à l'art<\/strong>. D’autre part, nous veillons à ce que chaque livre <strong>véhicule des valeurs authentiques<\/strong> pour guider\n      chaque enfant dans la construction de ses <strong>idéaux<\/strong> et de ses actions.\n    <\/p>\n    <p>\n      Enfin, le livre doit <strong>cultiver le naturel optimiste<\/strong> de l’enfant, en lui apportant une <strong>vision positive du monde<\/strong>, renforçant\n      ainsi sa <strong>confiance en soi<\/strong> et son <strong>goût de la vie<\/strong>. Notre objectif est d'offrir des lectures qui contribuent à\n      <strong>l'épanouissement de l'âme<\/strong> et au <strong>développement de l’esprit critique<\/strong>.\n    <\/p>\n  <\/div>","section_height":"default","full_width":true,"dividers":"none","prevent_animation":false}},"pave_seo_collection_dU3M9U":{"type":"pave-seo-collection","name":"Bloc pavé SEO collec","settings":{"text_align":"left","justify":true,"disable_wrapper":false}}},"order":["collection-banner","custom_text_block_CVDhhc","custom_text_block_7YK6Pa","sous_categories_par_age_FhqP3t","collection-products","custom_liquid_jdqEpG","featured_collection_FqpwD4","custom_liquid_D9Ugqz","featured_collection_WCrmMR","custom_liquid_3rHBgq","featured_collection_TUNHHa","suggested_products_m6YjVz","featured_collection_yQ4UCq","56445b7d-2f48-434d-87ae-795e434f4edb","icons_with_text_f78eBN","custom_liquid_XUpbEa","pave_seo_collection_dU3M9U"]}