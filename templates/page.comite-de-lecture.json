el":"","button_2_link":"","button_2_style":"btn btn--primary","transparent_content_color":"#ffffff","countdown_show":false,"countdown_end_date":"","countdown_end_time":"","countdown_end_text":"","enlarge_end_text":false,"countdown_hide_on_end":false,"use_custom_colors":false,"count_color":"#ffffff","bg_color":"#ffffff","bg_grad":""}}},"block_order":["slide_43GkUE","slide_FdmDTH","slide_YDmyg7"],"custom_css":["slide-show {padding-bottom: 50px; margin-top: -50px;}",".slideshow__slide img {object-fit: contain !important; \/* ou 'cover' selon ton besoin *\/}",".slideshow-nav {transform: translateY(30px); color: black;}"],"name":"Carrousel d'images","settings":{"height_mode":"auto","fixed_height_desktop":400,"fixed_height_mobile":500,"mobile_stacked":false,"nav_style":"arrows","pagination_color":"#ffffff","nav_position":"justify-center","transition":"fade","autoplay":false,"slider_pause":false,"autoplay_speed":5,"color_scheme":"white","full_width":false,"tint_color":"rgba(0,0,0,0)","tint_opacity":0,"accessibility_info":"","prevent_animation":true}},"custom_text_block_QRFWwC":{"type":"custom-text-block","name":"Eveiller les esprits par ...","settings":{"title":"Éveiller les esprits par des lectures éclairées","title_anchor_id":"","mobile_center":true,"heading_tag":"h2","heading_style_class":"h3","text":"","text_align":"left","p_align":"left","title_margin_top":"50","title_margin_bottom":"20","p_margin_top":"20","p_margin_bottom":"20"}},"custom_text_block_8jYQAn":{"type":"custom-text-block","name":"Le comité s'attache à ...","settings":{"title":"","title_anchor_id":"","mobile_center":true,"heading_tag":"p","heading_style_class":"h3","text":"<p>Le comité s’attache à évaluer chaque livre selon <strong>les quatre critères fondamentaux de notre matrice vertueuse: <\/strong>la qualité esthétique, la richesse linguistique, les valeurs humaines transmises et l’élan d’optimisme qu’il porte. Ces avis visent à promouvoir une littérature jeunesse exigeante, inspirante et porteuse de sens.<\/p><p>Ce travail d’évaluation repose sur une démarche rigoureuse et approfondie. Pour chaque ouvrage lu, <strong>une fiche de lecture<\/strong> est dûment remplie par les lectrices. Celle-ci comporte: une note globale, une note pour chacun des<strong> <\/strong>4 critères fondamentaux de notre matrice vertueuse, une classification par tranche d’âge, par vertus mises en avant, par genre littéraire et par centres d’intérêt. Des mots-clés sont également sélectionnés avec soin afin de faciliter le repérage des thématiques principales. <\/p><p>Ce processus minutieux permet ensuite <strong>la rédaction d’un avis construit<\/strong>, fidèle à l’expérience de lecture, et guidé par le souci constant de proposer une littérature jeunesse<strong> <\/strong>de qualité. <\/p>","text_align":"center","p_align":"left","title_margin_top":"40","title_margin_bottom":"20","p_margin_top":"20","p_margin_bottom":"20"}},"contact_form_HdGizK":{"type":"contact-form","blocks":{"name_mRmWYN":{"type":"name","settings":{"required":true,"half_width":true}},"email_93n9bT":{"type":"email","settings":{"required":true,"half_width":true}},"dropdown_4eq7wJ":{"type":"dropdown","settings":{"title":"Comment pouvons-nous vous aider ?","options":"Trouver un livre\nBesoin de recommandation\nBesoin d'aide avec ma commande\nJe souhaite faire partie du comité\nJe représente une école\nJe suis une librairie","half_width":false}},"body_dzBxCK":{"type":"body","settings":{"required":true,"half_width":false}}},"block_order":["name_mRmWYN","email_93n9bT","dropdown_4eq7wJ","body_dzBxCK"],"custom_css":["{margin-top: 50px;}"],"name":"Contact form","settings":{"heading":"Vous souhaitez rejoindre notre mission ? Contactez nous !","heading_align":"text-center","image_position":"top","color_scheme":"1","full_width":true,"button_style":"btn btn--primary"}},"custom_text_block_FRFjtj":{"type":"custom-text-block","name":"Découvrez notre sélection","settings":{"title":"Découvrez notre sélection :","title_anchor_id":"","mob