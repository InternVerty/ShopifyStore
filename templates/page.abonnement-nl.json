    "custom_liquid_qhKHDP": {
      "type": "custom-liquid",
      "name": "Custom HTML/Liquid",
      "settings": {
        "custom_liquid": "{% comment %}\n  Hero centré avec fond arrondi + image posée à droite\n{% endcomment %}\n\n\n<section class=\"abo-hero \">\n  <div class=\"abo-hero__bg \">\n    <div class=\"abo-hero__inner \">\n      <h2 class=\"abo-hero__title h4\">Un abonnement personnalisé à chaque enfant!</h2>\n      <p class=\"abo-hero__subtitle\">\n        Dites-nous ce que votre enfant aime, nous adaptons la sélection à son âge, son niveau de lecture et ses centres d’intérêts!\n      </p>\n      <a class=\"abo-hero__btn\" href=\"https://verty.eu/pages/formulaire-verty\">J'abonne un enfant</a>\n    </div>\n\n    <img\n      class=\"abo-hero__image\"\n      src=\"https://cdn.shopify.com/s/files/1/0844/5447/4021/files/boxcar_all.png?v=1769171577\"\n      alt=\"\"\n      loading=\"lazy\"\n    >\n  </div>\n</section>\n\n<style>\n  .abo-hero{\n    padding: 48px 0px;\n  }\n\n  /* Fond centré, pas full width */\n  .abo-hero__bg{\n    position: relative;\n    max-width:1260px;\n    margin: 0 auto;\n    background:rgba(213, 246, 233, 0.6);\n    border-radius: 24px;\n    padding: 56px 0px;\n    overflow: visible; /* autorise le dépassement de l’image */\n  }\n\n  /* Texte centré */\n  .abo-hero__inner{\n    max-width: 820px;\n    margin: 0 auto;\n    text-align: center;\n    position: relative;\n    z-index: 2;\n  }\n\n  .abo-hero__title{\n    margin: 0 0 12px;\n    line-height: 1.1;\n  }\n\n  .abo-hero__subtitle{\n    margin: 0 0 18px;\n    line-height: 1.5;\n  }\n\n  .abo-hero__btn{\n    display: inline-block;\n    background: #97E8C7;\n    color: #0b0b0b;\n    text-decoration: none;\n    padding: 14px 20px;\n    border-radius: 50px;\n    border: 2px solid;\n    border-color: #6ECFB5;\n    font-weight: 700;\n    transition: transform .15s ease, box-shadow .15s ease, filter .15s ease;\n  }\n\n  .abo-hero__btn:hover{\n  transform: translateY(-2px);\n  filter: brightness(1.03);\n}\n\n.abo-hero__btn:active{\n  transform: translateY(0);\n}\n\n  /* Image posée à droite du fond */\n  .abo-hero__image{\n    position: absolute;\n    right: -60px; /* dépassement */\n    top: 70%;\n    transform: translateY(-50%);\n    width: 420px;\n    height: auto;\n    z-index: 1;\n    pointer-events: none;\n  }\n\n  /* Tablet */\n  @media (max-width: 999px){\n    .abo-hero__image{\n      width: 320px;\n      right: -40px;\n    }\n  }\n\n  /* Mobile */\n  @media (max-width: 749px){\n    .abo-hero__bg{\n      padding: 40px 16px 28px;\n    }\n\n    .abo-hero__title{\n      font-size: 30px;\n    }\n\n    .abo-hero__image{\n      position: static;\n      transform: none;\n      display: block;\n      margin: 24px auto 0;\n      width: min(360px, 86vw);\n      pointer-events: auto;\n    }\n  }\n</style>",
        "section_height": "default",
        "full_width": false,
        "dividers": "none",
        "prevent_animation": false
      }
    },
