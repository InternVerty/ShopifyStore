ustom-html-reader-metafield","name":"Texte 3","settings":{"namespace_key":"custom.texte_h2_3_collec_temporaire","text_align":"left","justify":true,"tag_type":"p","tag_class":"p","disable_wrapper":true}},"custom_html_reader_metafield_iaprDw":{"type":"custom-html-reader-metafield","custom_css":["{margin-top: 40px;}"],"name":"Titre 4","settings":{"namespace_key":"custom.titre_h2_4_collec_temporaire","text_align":"left","justify":true,"tag_type":"h2","tag_class":"h4","disable_wrapper":false}},"custom_html_reader_metafield_jcgNNw":{"type":"custom-html-reader-metafield","name":"Texte 4","settings":{"namespace_key":"custom.texte_h2_4_collec_temporaire","text_align":"left","justify":true,"tag_type":"p","tag_class":"p","disable_wrapper":false}},"custom_liquid_XUpbEa":{"type":"custom-liquid","custom_css":[],"name":"Comité de lecture selec...","settings":{"custom_liquid":"<div class=\"container\">\n    <h2 class=\"h4\">Le comité de lecture Verty sélectionne les meilleurs livres pour enfants<\/h2>\n<p> Notre <strong>comité de lecture<\/strong>, composé d'institutrices, d'orthophonistes, de psychologues, de parents, tous\n      <strong>passionnés de littérature jeunesse<\/strong> et investis d’une mission essentielle : <strong>transmettre le goût de la lecture<\/strong> à tous les enfants\n      et mettre entre leurs mains des livres qui les aideront à se construire avec des <strong>repères solides<\/strong>. <\/p>\n    <p>\n      Le comité de lecture <strong>sélectionne avec soin<\/strong> les <strong>meilleurs livres pour enfants<\/strong> en s'appuyant sur plusieurs critères essentiels.\n      Nous privilégions des ouvrages <strong>écrits dans une belle langue<\/strong>, avec un <strong>style d'écriture de qualité<\/strong> et un <strong>vocabulaire riche<\/strong>,\n      afin de <strong>nourrir le développement intellectuel<\/strong> des jeunes lecteurs.\n    <\/p>\n    <p>\n      La <strong>qualité esthétique<\/strong> des illustrations et de la couverture est également prise en compte, car nous croyons en leur pouvoir\n      d’<strong>éveiller l'enfant à l'art<\/strong>. D’autre part, nous veillons à ce que chaque livre <strong>véhicule des valeurs authentiques<\/strong> pour guider\n      chaque enfant dans la construction de ses <strong>idéaux<\/strong> et de ses actions.\n    <\/p>\n    <p>\n      Enfin, le livre doit <strong>cultiver le naturel optimiste<\/strong> de l’enfant, en lui apportant une <strong>vision positive du monde<\/strong>, renforçant\n      ainsi sa <strong>confiance en soi<\/strong> et son <strong>goût de la vie<\/strong>. Notre objectif est d'offrir des lectures qui contribuent à\n      <strong>l'épanouissement de l'âme<\/strong> et au <strong>développement de l’esprit critique<\/strong>.\n    <\/p>\n  <\/div>","section_height":"default","full_width":true,"dividers":"none","prevent_animation":false}},"icons_with_text_f78eBN":{"type":"icons-with-text","blocks":{"item_jC6bwY":{"type":"item","settings":{"icon":"truck","custom_icon":"shopify:\/\/shop_images\/Icone_camion_V3.png","heading":"Livraison rapide et sécurisée","text":"<p>Gratuite à partir de 129€<\/p>","link":""}},"item_zPTXEr":{"type":"item","settings":{"icon":"price_tag","custom_icon":"shopify:\/\/shop_images\/Icone_livre_VF.png","heading":"+ 2000 livres","text":"<p>Choisis par notre comité de lecture<\/p>","link":""}},"item_t9mDY7":{"type":"item","settings":{"icon":"return","custom_icon":"shopify:\/\/shop_images\/Icone_service_client_VF.png","heading":"Service client à l'écoute","text":"<p>Réponse en 24h ouvrées<\/p>","link":""}},"item_VazcQd":{"type":"item","settings":{"icon":"award","custom_icon":"shopify:\/\/shop_images\/Image_paiement_V3.png","heading":"Paiement 100% sécurisé","text":"<p>Sécurité 3D secure<\/p>","link":""}}},"block_order":["item_jC6bwY","item_zPTXEr","item_t9mDY7","item_VazcQd"],"settings":{"heading":"","heading_align":"text-start","icon_size":76,"title_type_scale":"large","text_type_scale":"small","icon_position":"above","mobile