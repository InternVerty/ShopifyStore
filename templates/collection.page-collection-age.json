style":"btn btn--primary"}},"rich_text_tAaN9q":{"type":"rich-text","custom_css":[".max-w-text-overlay {max-width: 100% !important; width: 100% !important;}",".section__block--heading {width: 100% !important; display: block;}",".div {display: block !important; width: 100% !important; white-space: nowrap; \/* Empêche le retour à la ligne *\/}"],"settings":{"text_position":"justify-start","text_align":"text-start","mob_center_text":true,"color_scheme":"none","full_width":true,"prevent_animation":true}},"sous_categories_par_age_zV3fTM":{"type":"sous-categories-par-age","settings":{"heading":"{{ collection.metafields.custom.titre_bouton_sous_categorie.value }}","heading_tag":"h2","heading_style":"h4","text_align":"left","description":"","heading_color":"#000000","button_text_color":"#ffffff","button_bg_color":"#8fcdbf","button_border_color":"#ffffff"}},"custom_liquid_EP7TDX":{"type":"custom-liquid","name":"Custom HTML\/Liquid","settings":{"custom_liquid":"<section class=\"explication-selection\">\n  <div class=\"container\">\n    <h2 class=\"h4\">Le comité de lecture Verty sélectionne les meilleurs livres pour enfants<\/h2>\n<p> Notre <strong>comité de lecture<\/strong>, composé d'institutrices, d'orthophonistes, de psychologues, de parents, tous\n      <strong>passionnés de littérature jeunesse<\/strong> et investis d’une mission essentielle : <strong>transmettre le goût de la lecture<\/strong> à tous les enfants\n      et mettre entre leurs mains des livres qui les aideront à se construire avec des <strong>repères solides<\/strong>. <\/p>\n    <p>\n      Le comité de lecture <strong>sélectionne avec soin<\/strong> les <strong>meilleurs livres pour enfants<\/strong> en s'appuyant sur plusieurs critères essentiels.\n      Nous privilégions des ouvrages <strong>écrits dans une belle langue<\/strong>, avec un <strong>style d'écriture de qualité<\/strong> et un <strong>vocabulaire riche<\/strong>,\n      afin de <strong>nourrir le développement intellectuel<\/strong> des jeunes lecteurs.\n    <\/p>\n    <p>\n      La <strong>qualité esthétique<\/strong> des illustrations et de la couverture est également prise en compte, car nous croyons en leur pouvoir\n      d’<strong>éveiller l'enfant à l'art<\/strong>. D’autre part, nous veillons à ce que chaque livre <strong>véhicule des valeurs authentiques<\/strong> pour guider\n      chaque enfant dans la construction de ses <strong>idéaux<\/strong> et de ses actions.\n    <\/p>\n    <p>\n      Enfin, le livre doit <strong>cultiver le naturel optimiste<\/strong> de l’enfant, en lui apportant une <strong>vision positive du monde<\/strong>, renforçant\n      ainsi sa <strong>confiance en soi<\/strong> et son <strong>goût de la vie<\/strong>. Notre objectif est d'offrir des lectures qui contribuent à\n      <strong>l'épanouissement de l'âme<\/strong> et au <strong>développement de l’esprit critique<\/strong>.\n    <\/p>\n  <\/div>\n<\/section>","section_height":"default","full_width":true,"dividers":"none","prevent_animation":false}},"custom_html_reader_metafield_gtahhb":{"type":"custom-html-reader-metafield","name":"TITRE elem regardés par comité pour cet age","settings":{"namespace_key":"custom.h3_titre_elements_regardes_par_le_comite_pour_cet_age","text_align":"left","justify":true,"tag_type":"h3","tag_class":"h6","disable_wrapper":false}},"custom_html_reader_metafield_U4fTiK":{"type":"custom-html-reader-metafield","name":"Paragraphe elem regardés par comité pour cet age","settings":{"namespace_key":"custom.h3_elements_regardes_par_le_comite_pour_cet_age","text_align":"left","justify":true,"tag_type":"p","tag_class":"p","disable_wrapper":false}},"custom_html_reader_metafield_qUXBVe":{"type":"custom-html-reader-metafield","custom_css":["{margin-top: 40px;}"],"name":"TITRE importance lecture ","settings":{"namespace_key":"custom.h2_titre_importance_pour_les_enfants_de_cet_age_de_lire","text_align":"left","justify":true,"tag_type":"h2","tag_class":"h4","disable_wrapper":false}},"custom_html_reade