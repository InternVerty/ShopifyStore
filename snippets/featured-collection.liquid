{%- liquid
  assign featured_collection = block.settings.collection

  assign carousel_desktop_small_promo = ' sm:auto-cols-3 md:auto-cols-2 lg:auto-cols-3 xl:auto-cols-4 small-cards-desktop'
  assign carousel_desktop_medium_promo = ' sm:auto-cols-2 lg:auto-cols-3'
  assign carousel_desktop_large_promo = ' sm:auto-cols-2'
  assign carousel_desktop_small = ' md:auto-cols-3 lg:auto-cols-4 xl:auto-cols-5 small-cards-desktop'
  assign carousel_desktop_medium = ' sm:auto-cols-3 xl:auto-cols-4'
  assign carousel_desktop_large = ' sm:auto-cols-2 lg:auto-cols-3'

  assign grid_desktop_small_promo = ' sm:grid-cols-3 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 small-cards-desktop'
  assign grid_desktop_medium_promo = ' md:grid-cols-2 lg:grid-cols-3'
  assign grid_desktop_large_promo = ' sm:grid-cols-2'
  assign grid_desktop_small = ' md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 small-cards-desktop'
  assign grid_desktop_medium = ' sm:grid-cols-3 xl:grid-cols-4'
  assign grid_desktop_large = ' sm:grid-cols-2 lg:grid-cols-3'

  if block.settings.card_size_mobile == 'small'
    assign carousel_mobile_cols = 'grid-flow-col auto-cols-2 small-cards-mobile'
    assign grid_mobile_cols = 'grid-cols-2 small-cards-mobile'
  else
    assign carousel_mobile_cols = 'grid-flow-col auto-cols-1'
    assign grid_mobile_cols = 'grid-cols-1'
  endif

  if block.settings.layout == 'carousel'
    assign carousel = true

    if block.settings.show_promo_info
      if block.settings.card_size == 'small'
        assign grid_classes = carousel_mobile_cols | append: carousel_desktop_small_promo
      elsif block.settings.card_size == 'medium'
        assign grid_classes = carousel_mobile_cols | append: carousel_desktop_medium_promo
      else
        assign grid_classes = carousel_mobile_cols | append: carousel_desktop_large_promo
      endif
    else
      if block.settings.card_size == 'small'
        assign grid_classes = carousel_mobile_cols | append: carousel_desktop_small
      elsif block.settings.card_size == 'medium'
        assign grid_classes = carousel_mobile_cols | append: carousel_desktop_medium
      else
        assign grid_classes = carousel_mobile_cols | append: carousel_desktop_large
      endif
    endif
  elsif block.settings.layout == 'carousel_on_mobile'
    assign carousel = true

    if block.settings.show_promo_info
      if block.settings.card_size == 'small'
        assign grid_classes = carousel_mobile_cols | append: grid_desktop_small_promo
      elsif block.settings.card_size == 'medium'
        assign grid_classes = carousel_mobile_cols | append: grid_desktop_medium_promo
      else
        assign grid_classes = carousel_mobile_cols | append: grid_desktop_large_promo
      endif
    else
      if block.settings.card_size == 'small'
        assign grid_classes = carousel_mobile_cols | append: grid_desktop_small
      elsif block.settings.card_size == 'medium'
        assign grid_classes = carousel_mobile_cols | append: grid_desktop_medium
      else
        assign grid_classes = carousel_mobile_cols | append: grid_desktop_large
      endif
    endif
  elsif block.settings.layout == 'grid'
    assign carousel = false

    if block.settings.show_promo_info
      if block.settings.card_size == 'small'
        assign grid_classes = grid_mobile_cols | append: grid_desktop_small_promo
      elsif block.settings.card_size == 'medium'
        assign grid_classes = grid_mobile_cols | append: grid_desktop_medium_promo
      else
        assign grid_classes = grid_mobile_cols | append: grid_desktop_large_promo
      endif
    else
      if block.settings.card_size == 'small'
        assign grid_classes = grid_mobile_cols | append: grid_desktop_small
      elsif block.settings.card_size == 'medium'
        assign grid_classes = grid_mobile_cols | append: grid_desktop_medium
      else
        assign grid_classes = grid_mobile_cols | append: grid_desktop_large
      endif
    endif
  endif

  if settings.prod_card_image_ratio == 'shortest'
    assign image_ratio = 0
    for product in featured_collection.products limit: block.settings.products_to_show
      if product.featured_media.preview_image.aspect_ratio > image_ratio
        assign image_ratio = product.featured_media.preview_image.aspect_ratio
      endif
    endfor
  elsif settings.prod_card_image_ratio == 'tallest'
    assign image_ratio = 99
    for product in featured_collection.products limit: block.settings.products_to_show
      if product.featured_media.preview_image.aspect_ratio < image_ratio
        assign image_ratio = product.featured_media.preview_image.aspect_ratio
      endif
    endfor
  else
    assign image_ratio = settings.prod_card_image_ratio
  endif

  assign color_scheme = block.settings.color_scheme
  assign bg_color = false

  if color_scheme == 'default'
    assign bg_color = settings.bg_color
  elsif color_scheme == '1'
    assign bg_color = settings.color_scheme_1_bg_grad | default: settings.color_scheme_1_bg
  elsif color_scheme == '2'
    assign bg_color = settings.color_scheme_2_bg_grad | default: settings.color_scheme_2_bg
  elsif color_scheme == '3'
    assign bg_color = settings.color_scheme_3_bg_grad | default: settings.color_scheme_3_bg
  endif

  if bg_color == settings.bg_color or bg_color == 'rgba(0,0,0,0)'
    assign bg_color = false
  endif
-%}

<div class="section l-featured-collection {% if hide == true %}l-hide{% endif %}">
  {%- if block.settings.title != blank or block.settings.show_view_all -%}
    <div class="container">
      <div class="section__header items-center flex{% if block.settings.heading_align == 'text-center' %} flex-col text-center{% elsif block.settings.heading_align == 'text-end' %} flex-row-reverse flex-wrap{% else %} flex-row flex-wrap{% endif %} gap-x-theme"{% if settings.animations_enabled != "disabled" %} data-cc-animate{% endif %}>
        {%- if block.settings.title != blank -%}
          <h2 class="h4 mb-0 flex-auto section__heading {{ block.settings.heading_align }}">
            {{- block.settings.title | escape -}}
          </h2>
        {%- endif -%}

        {%- if block.settings.show_view_all -%}
          <a href="{{ featured_collection.url }}" class="link">{{ 'sections.featured_collection.view_all' | t }}</a>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  {%- if block.settings.show_promo_info -%}
    <div class="featured-collection-container relative w-full mx-auto"{% if block.settings.image_ratio == 'fill' and block.settings.layout != 'carousel' and block.settings.image %} data-css-var-height=".card--product"{% endif %}>
      <div class="flex flex-col md:flex-row">

        <div class="featured-collection-info mb-6 md:mb-0 flex shrink-0 flex-col{% if block.settings.layout == 'carousel' %} featured-collection-info--carousel items-stretch{% endif %}"{% if settings.animations_enabled != "disabled" %}data-cc-animate{% endif %}>
          {%- if block.settings.layout == 'grid' or block.settings.layout == 'carousel_on_mobile' -%}
            <div class="featured-collection--sticky{% if block.settings.image_ratio == 'fill' and block.settings.layout != 'carousel' and block.settings.image %} featured-collection--sticky-fill flex flex-col{% endif %}">
          {% endif %}

            {% if block.settings.image %}
              {%- liquid
              assign image_ratio_int = block.settings.image_ratio
              if image_ratio_int == "natural" or image_ratio_int == "fill"
                assign image_ratio_int = block.settings.image.aspect_ratio
              endif

              assign image_fill = false
              if block.settings.image_ratio == "fill"
                assign image_fill = true
              endif
            -%}

            <div class="featured-collection-image{% if image_fill %} h-full{% endif %}">
              {% if block.settings.link_url %}
                <a href="{{ block.settings.link_url }}" aria-label="{{ block.settings.promo_title | escape }}" class="media block relative w-full{% if image_fill %} h-full md:pt-0{% endif %}" style="padding-top: {{ 1 | divided_by: image_ratio_int | times: 100 }}%;">
              {%- else -%}
                <div class="media relative w-full{% if image_fill %} h-full{% if carousel %} md:pt-0{% endif %}{% endif %}" style="padding-top: {{ 1 | divided_by: image_ratio_int | times: 100 }}%;">
              {%- endif -%}

                  {% render 'image',
                    image: block.settings.image,
                    widths: '320, 460, 600, 700, 800, 900, 1200',
                    src_width: 460,
                    src_placeholder: true,
                    sizes: false,
                    class: 'img-fit img-fit--cover' %}

              {%- if block.settings.link_url -%}
                </a>
              {%- else -%}
                </div>
              {%- endif -%}
            </div>
          {% endif %}

            {%- if block.settings.promo_title != blank or block.settings.content != blank or block.settings.button_label != blank -%}
              <div class="featured-collection-text{% unless block.settings.image.aspect_ratio == "fill" %} flex flex-col grow{% endunless %}{% if bg_color %} p-6{% else %} mt-6{% endif %}{% unless color_scheme == 'none' %} color-scheme color-scheme--{{ color_scheme }}{% endunless %}">
                {%- unless block.settings.promo_title == blank -%}
                  <h2 class="h4 section__heading">{{ block.settings.promo_title }}</h2>
                {%- endunless -%}

                <div class="grow">
                  {%- if block.settings.content != blank -%}
                    <div class="rte">{{ block.settings.content }}</div>
                  {%- endif -%}
                </div>

                {%- if block.settings.button_label != blank -%}
                  <a class="{{ block.settings.button_style }} block mt-8 w-full" {% if block.settings.link_url != blank %}href="{{ block.settings.link_url }}"{% else %}role="link"aria-disabled="true"{% endif %}>
                    {{- block.settings.button_label | escape -}}
                  </a>
                {%- endif -%}
              </div>
            {%- endif -%}

          {%- if block.settings.layout == 'grid' or block.settings.layout == 'carousel_on_mobile' -%}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if carousel -%}
        <carousel-slider class="carousel block{% if block.settings.show_promo_info %} grow{% endif %}" inactive{% if block.settings.layout == 'carousel_on_mobile' %} disable-desktop="true"{% endif %}>
          <div class="{% unless block.settings.show_promo_info %}container relative{% endunless %} featured-collection-products">
            <div class="slider" id="slider-{{ section.id }}">
            {%- endif -%}

            <div class="container products-grid-container shrink-0">
              <ul class="{% if carousel %}slider__grid {% endif %}grid {{ grid_classes }}{% if block.settings.layout == 'carousel_on_mobile' and block.settings.card_size_mobile == 'small' and settings.card_contain %} sm:gap-x-theme sm:gap-y-8{% else %} gap-x-theme gap-y-8{% endif %}{% if block.settings.card_size_mobile == 'small' and settings.card_contain %} small__grid{% endif %}" role="list">
                {%- for product in featured_collection.products limit: block.settings.products_to_show -%}
                  <li {% if carousel %}class="slider__item"{% endif %}{% if settings.animations_enabled != "disabled" %}data-cc-animate data-cc-animate-delay="{{ forloop.index | times: 0.07 }}s"{% endif %}>
                    {% render 'product-card', product: product, collection: featured_collection, image_ratio: image_ratio, show_metafields: true %}
                  </li>
                {%- else -%}
                  {%- for i in (1..block.settings.products_to_show) -%}
                    <li {% if carousel %}class="slider__item"{% endif %}{% if settings.animations_enabled != "disabled" %}data-cc-animate data-cc-animate-delay="{{ forloop.index | times: 0.07 }}s"{% endif %}>
                      {% render 'product-card', product: "", image_ratio: image_ratio %}
                    </li>
                  {%- endfor -%}
                {%- endfor -%}
              </ul>
            </div>

            {%- if carousel -%}
            </div>

            {%- if settings.slider_show_arrows != 'never' -%}
              <div class="slider-nav absolute top-middle end {% if settings.slider_show_arrows == 'hover' %}slider-nav--show-on-hover no-hover-hidden {% endif %}hidden md:block no-js-hidden">
                <button type="button" class="slider-nav__btn tap-target btn {{ settings.slider_button_style }} has-ltr-icon" name="next" aria-controls="slider-{{ section.id }}">
                  <span class="visually-hidden">{{ 'general.slider.next' | t }}</span>
                  {% render 'icon-chevron-right' %}
                </button>
                <button type="button" class="slider-nav__btn tap-target btn {{ settings.slider_button_style }} has-ltr-icon" name="prev" aria-controls="slider-{{ section.id }}">
                  <span class="visually-hidden">{{ 'general.slider.previous' | t }}</span>
                  {% render 'icon-chevron-left' %}
                </button>
              </div>
            {%- endif -%}
          </div>
        </carousel-slider>
      {%- endif -%}
      {%- if block.settings.show_promo_info -%}
      </div>
    </div>
  {%- endif -%}
</div>
