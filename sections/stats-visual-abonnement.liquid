    { "type": "text",   "id": "left_footnote",         "label": "Note de bas",               "default": "*Pour un enfant de 4ème. Faites-Les Lire! Michel Desmurget - 2023" },

    { "type": "header", "content": "━━ CELLULE D — Texte droite bas ━━" },
    { "type": "richtext","id": "right_text",           "label": "Texte",                     "default": "<p>Et qu'heureusement vous êtes <strong>2 mères sur 3</strong> à pousser vos enfants à lire…</p>" },
    { "type": "color",  "id": "right_text_color",      "label": "Couleur",                   "default": "#111111" },
    { "type": "range",  "id": "right_text_size",       "label": "Taille (px)",               "min": 12, "max": 32, "step": 1, "default": 22 },
    { "type": "select", "id": "right_text_weight",     "label": "Graisse",                   "default": "400",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ]
    },
    { "type": "range",  "id": "right_text_lh",         "label": "Interligne (×10)",          "min": 10, "max": 22, "step": 1, "default": 15 },
    { "type": "select", "id": "right_text_align",      "label": "Alignement texte",          "default": "center",
      "options": [
        { "value": "left",   "label": "Gauche" },
        { "value": "center", "label": "Centre" },
        { "value": "right",  "label": "Droite" }
      ]
    },
    { "type": "select", "id": "right_text_valign",     "label": "Alignement vertical (D)",   "default": "flex-start",
      "options": [
        { "value": "flex-start", "label": "Haut" },
        { "value": "center",     "label": "Milieu" },
        { "value": "flex-end",   "label": "Bas" }
      ]
    },
    { "type": "text",   "id": "right_footnote",        "label": "Note de bas",               "default": "-" },

    { "type": "header", "content": "━━ NOTE DE BAS ━━" },
