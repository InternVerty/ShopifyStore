{% comment %}
  Section: Image Block — object-fit + focal point
  File: sections/image-block.liquid
{% endcomment %}

{%- assign bg_opacity = section.settings.bg_opacity | divided_by: 100.0 -%}
{%- assign bg = section.settings.bg_color | color_modify: 'alpha', bg_opacity -%}

<section class="ib" id="ib-{{ section.id }}" style="
  background-color: {{ bg }};
  padding: {{ section.settings.section_pad_v }}px {{ section.settings.section_pad_h }}px;
  margin-top: {{ section.settings.margin_top }}px;
  margin-bottom: {{ section.settings.margin_bottom }}px;
">
  <div class="ib__wrap" style="
    max-width: {{ section.settings.max_width }}px;
    border-radius: {{ section.settings.radius }}px;
  ">
    {%- if section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 2400 }}"
        srcset="{{ section.settings.image | image_url: width: 400 }} 400w,
                {{ section.settings.image | image_url: width: 800 }} 800w,
                {{ section.settings.image | image_url: width: 1200 }} 1200w,
                {{ section.settings.image | image_url: width: 1600 }} 1600w,
                {{ section.settings.image | image_url: width: 2000 }} 2000w,
                {{ section.settings.image | image_url: width: 2400 }} 2400w"
        sizes="100vw"
        alt="{{ section.settings.image.alt | escape }}"
        loading="lazy"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
        class="ib__img"
        style="object-position: {{ section.settings.image.presentation.focal_point }};"
      >
    {%- else -%}
      <div class="ib__placeholder">
        <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
        <p>Add an image — the focal point is set by clicking on the image in Shopify Admin → Content → Files</p>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  #ib-{{ section.id }}.ib {
    width: 100%;
    display: flex;
    justify-content: center;
    box-sizing: border-box;
  }

  #ib-{{ section.id }} .ib__wrap {
    width: 100%;
    height: {{ section.settings.height }}px;
    overflow: hidden;
    position: relative;
  }

  #ib-{{ section.id }} .ib__img {
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.object_fit }};
    display: block;
  }

  #ib-{{ section.id }} .ib__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    color: #aaa;
    font-size: 13px;
    text-align: center;
    padding: 24px;
    background: #f5f5f5;
    box-sizing: border-box;
  }

  @media (max-width: {{ section.settings.mobile_breakpoint }}px) {
    #ib-{{ section.id }}.ib {
      padding: {{ section.settings.mobile_pad_v }}px {{ section.settings.mobile_pad_h }}px;
    }

    #ib-{{ section.id }} .ib__wrap {
      height: {{ section.settings.mobile_height }}px;
      border-radius: {{ section.settings.mobile_radius }}px;
      margin-top: {{ section.settings.mobile_margin_top }}px;
      margin_bottom: {{ section.settings.mobile_margin_bottom }}px; 
    }

    #ib-{{ section.id }} .ib__img {
      object-fit: {{ section.settings.mobile_object_fit }};
    }
  }

  @media (min-width: {{ section.settings.mobile_breakpoint }}) {
    #ib-{{ section.id }} .ib__img {
        transform: scale({{ section.settings.zoom | divided_by: 100.0 }});
        transform-origin: {{ section.settings.image.presentation.focal_point }};
    }
  }
</style>

{% schema %}
{
  "name": "Image Block",
  "tag": "section",
  "settings": [

    { "type": "header", "content": "━━ IMAGE ━━" },
    { "type": "image_picker", "id": "image", "label": "Image",
      "info": "To set the focal point (crop center): go to Shopify Admin → Content → Files, click the image, then click 'Set focal point'." },

    { "type": "header", "content": "━━ SECTION ━━" },
    { "type": "color",  "id": "bg_color",         "label": "Background color",          "default": "#ffffff" },
    { "type": "range",  "id": "bg_opacity",        "label": "Background opacity (%)",    "min": 0, "max": 100, "step": 5, "unit": "%", "default": 100 },
    { "type": "range",  "id": "section_pad_v",     "label": "Padding vertical (px)",     "min": 0, "max": 120, "step": 4, "default": 0 },
    { "type": "range",  "id": "section_pad_h",     "label": "Padding horizontal (px)",   "min": 0, "max": 120, "step": 4, "default": 0 },
    { "type": "range",  "id": "max_width",         "label": "Max width (px)",            "min": 400, "max": 2400, "step": 20, "default": 1600 },
    { "type": "range",  "id": "radius",            "label": "Border radius (px)",        "min": 0, "max": 60, "step": 2, "default": 0 },
    { "type": "range",  "id": "margin_top",        "label": "Margin top (px)",           "min": -400, "max": 200, "step": 8, "default": 0 },
    { "type": "range",  "id": "margin_bottom",     "label": "Margin bottom (px)",        "min": -400, "max": 200, "step": 8, "default": 0 },

    { "type": "header", "content": "━━ DESKTOP ━━" },
    { "type": "range",  "id": "height",            "label": "Height (px)",               "min": 100, "max": 2000, "step": 20, "default": 500 },
    { "type": "range", "id": "zoom", "label": "Zoom (%)", "min": 0, "max": 200, "step": 5, "default": 100 },
    { "type": "select", "id": "object_fit",        "label": "Image fit",                 "default": "cover",
      "options": [
        { "value": "cover",   "label": "Cover — fills frame, crops excess" },
        { "value": "contain", "label": "Contain — full image visible, may letterbox" },
        { "value": "fill",    "label": "Fill — stretches to fit (no crop)" }
      ]
    },

    { "type": "header", "content": "━━ MOBILE ━━" },
    { "type": "range",  "id": "mobile_breakpoint", "label": "Breakpoint (px)",           "min": 480, "max": 1024, "step": 8, "default": 768 },
    { "type": "range",  "id": "mobile_pad_v",      "label": "Padding vertical (px)",     "min": 0, "max": 80, "step": 4, "default": 0 },
    { "type": "range",  "id": "mobile_pad_h",      "label": "Padding horizontal (px)",   "min": 0, "max": 80, "step": 4, "default": 0 },
    { "type": "range",  "id": "mobile_margin_top",        "label": "Margin top (px)",           "min": -500, "max": 100, "step": 8, "default": 4 },
    { "type": "range",  "id": "mobile_margin_bottom",     "label": "Margin bottom (px)",        "min": -500, "max": 100, "step": 8, "default": 4 },
    { "type": "range",  "id": "mobile_height",     "label": "Height (px)",               "min": 100, "max": 800, "step": 10, "default": 280 },
    { "type": "range",  "id": "mobile_radius",     "label": "Border radius (px)",        "min": 0, "max": 60, "step": 2, "default": 0 },
    { "type": "select", "id": "mobile_object_fit", "label": "Image fit",                 "default": "cover",
      "options": [
        { "value": "cover",   "label": "Cover — fills frame, crops excess" },
        { "value": "contain", "label": "Contain — full image visible, may letterbox" },
        { "value": "fill",    "label": "Fill — stretches to fit (no crop)" }
      ]
    }

  ],
  "presets": [
    { "name": "Image Block", "category": "Media" }
  ]
}
{% endschema %}
