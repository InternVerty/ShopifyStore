<!-- sections/boutons-collection.liquid -->
{% schema %}
{
  "name": "Boutons collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre de la section",
      "default": "Trouvez le livre idéal pour votre enfant"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Chaque enfant évolue à son propre rythme..."
    },
    {
  "type": "color",
  "id": "background_color",
  "label": "Couleur de fond",
  "default": "#f5faf9"
    },
    {
  "type": "color",
  "id": "button_color",
  "label": "Couleur des boutons",
  "default": "#8fcdbf"
    },
    {
  "type": "range",
  "id": "margin_top",
  "label": "Marge supérieure",
  "default": 20,
  "min": 0,
  "max": 100,
  "step": 5,
  "unit": "px"
    },
    {
  "type": "range",
  "id": "margin_bottom",
  "label": "Marge inférieure",
  "default": 20,
  "min": 0,
  "max": 100,
  "step": 5,
  "unit": "px"
    },
  ],
  "blocks": [
    {
      "type": "button",
      "name": "Bouton de collection",
      "settings": [
        {
          "type": "text",
          "id": "button_label",
          "label": "Texte du bouton",
          "default": "Avant 4 ans"
        },
        {
          "type": "collection",
          "id": "button_link",
          "label": "Sélectionner une collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Boutons collection",
      "category": "Custom"
    }
  ]
}
{% endschema %}

<section 
  class="boutons-collection-section"
  style="background-color: {{ section.settings.background_color }}; margin-top: {{ section.settings.margin_top }}px; margin-bottom: {{ section.settings.margin_bottom }}px;">
  <div class="boutons-collection-content container">
    <div class="boutons-collection-text">
      <h2 class="section__block section__block--heading md-down:px-gutter h4">{{ section.settings.heading }}</h2>
      <p>{{ section.settings.description }}</p>
    </div>
    <div class="button-container">
      {% for block in section.blocks %}
        {% if block.settings.button_link %}
          <a 
            href="{{ block.settings.button_link.url }}" 
            class="button-collection" 
            style="background-color: {{ section.settings.button_color }};"
          >
            {{ block.settings.button_label }}
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

