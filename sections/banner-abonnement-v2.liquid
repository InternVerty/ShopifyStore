{% comment %}
  Section: Hero Banner — Full bleed, image overflow
  File: sections/hero-banner.liquid
{% endcomment %}

{%- assign bg_opacity = section.settings.bg_opacity | divided_by: 100.0 -%}
{%- assign bg = section.settings.bg_color | color_modify: 'alpha', bg_opacity -%}

<section class="hb" id="hb-{{ section.id }}" style="background-color: {{ bg }};">
  <div class="hb__inner" style="max-width: {{ section.settings.max_width }}px;">

    <!-- ══════════ LEFT ══════════ -->
    <div class="hb__left" style="flex: {{ section.settings.left_flex }} 1 0;">

      {%- if section.settings.heading != blank -%}
        <h1 class="hb__heading" style="
          color: {{ section.settings.heading_color }};
          font-size: {{ section.settings.heading_size }}px;
          font-weight: {{ section.settings.heading_weight }};
          line-height: {{ section.settings.heading_lh | divided_by: 10.0 }};
          margin-bottom: {{ section.settings.heading_mb }}px;
        ">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.subtext != blank -%}
        <div class="hb__subtext" style="
          color: {{ section.settings.subtext_color }};
          font-size: {{ section.settings.subtext_size }}px;
          line-height: {{ section.settings.subtext_lh | divided_by: 10.0 }};
          margin-bottom: {{ section.settings.subtext_mb }}px;
        ">{{ section.settings.subtext }}</div>
      {%- endif -%}

      {%- if section.settings.btn_label != blank -%}
        <a href="{{ section.settings.btn_url }}" class="hb__btn" style="
          background-color: {{ section.settings.btn_bg }};
          color: {{ section.settings.btn_color }};
          border: {{ section.settings.btn_border_width }}px solid {{ section.settings.btn_border_color }};
          border-radius: {{ section.settings.btn_radius }}px;
          font-size: {{ section.settings.btn_font_size }}px;
          font-weight: {{ section.settings.btn_weight }};
          padding: {{ section.settings.btn_pad_v }}px {{ section.settings.btn_pad_h }}px;
          min-width: {{ section.settings.btn_min_width }}px;
        ">{{ section.settings.btn_label }}</a>
      {%- endif -%}

    </div>

    <!-- ══════════ RIGHT ══════════ -->
    <div class="hb__right" style="flex: {{ section.settings.right_flex }} 1 0;">
      {%- if section.settings.hero_image != blank -%}
        <div class="hb__img-wrap">
          {{
            section.settings.hero_image
            | image_url: width: 1000
            | image_tag:
              loading: 'eager',
              class: 'hb__img',
              widths: '400, 600, 800, 1000',
              alt: section.settings.hero_image.alt
          }}
        </div>
      {%- else -%}
        <div class="hb__img-placeholder">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
          <p>Ajouter une image</p>
        </div>
      {%- endif -%}
    </div>

  </div>
</section>

<style>
  #hb-{{ section.id }}.hb {
    width: 100%;
    display: flex;
    justify-content: center;
    padding: {{ section.settings.section_pad_v }}px {{ section.settings.section_pad_h }}px 0;
    box-sizing: border-box;
    overflow: visible;
  }

  #hb-{{ section.id }} .hb__inner {
    display: flex;
    align-items: flex-end;
    width: 100%;
    gap: {{ section.settings.columns_gap }}px;
    min-height: {{ section.settings.section_height }}px;
  }

  /* ── LEFT ── */
  #hb-{{ section.id }} .hb__left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding-bottom: {{ section.settings.left_pad_bottom }}px;
  }

  #hb-{{ section.id }} .hb__heading { margin: 0; letter-spacing: -0.5px; }
  #hb-{{ section.id }} .hb__subtext { margin: 0; max-width: 560px; }

  #hb-{{ section.id }} .hb__btn {
    display: inline-block;
    text-decoration: none;
    text-align: center;
    cursor: pointer;
    box-sizing: border-box;
    transition: opacity .2s, transform .15s;
  }
  #hb-{{ section.id }} .hb__btn:hover { opacity: .84; transform: translateY(-1px); }

  /* ── RIGHT ── */
  #hb-{{ section.id }} .hb__right {
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  #hb-{{ section.id }} .hb__img-wrap {
    width: 100%;
    max-width: {{ section.settings.image_max_width }}px;
    margin-bottom: {{ section.settings.image_offset_y }}px;
  }

  #hb-{{ section.id }} .hb__img {
    width: 100%;
    height: auto;
    display: block;
  }

  #hb-{{ section.id }} .hb__img-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 200px;
    color: #aaa;
    font-size: 13px;
    gap: 8px;
    width: 100%;
  }

  /* ══════════════════════════════
     MOBILE
  ══════════════════════════════ */
  @media (max-width: {{ section.settings.mobile_breakpoint }}px) {
    #hb-{{ section.id }}.hb {
      padding: {{ section.settings.mobile_pad_v }}px 0 0;
      overflow: hidden; /* évite le scroll horizontal */
    }

    #hb-{{ section.id }} .hb__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      min-height: auto;
      position: relative;
      padding-bottom: {{ section.settings.mobile_img_height }}px;
    }

    /* Texte : padding horizontal normal */
    #hb-{{ section.id }} .hb__left {
      padding: 0 {{ section.settings.mobile_pad_h }}px {{ section.settings.mobile_left_pb }}px;
      width: 100%;
      box-sizing: border-box;
    }

    {%- if section.settings.btn_full_mobile -%}
    #hb-{{ section.id }} .hb__btn {
      width: 100%;
      min-width: 0 !important;
      box-sizing: border-box;
    }
    {%- endif -%}

    /* Image : absolute, collée à droite, à cheval sur le bas */
    #hb-{{ section.id }} .hb__right {
      position: absolute;
      bottom: 0;
      right: 0;
      width: {{ section.settings.mobile_img_width }}%;
      align-items: flex-end;
      justify-content: flex-end;
    }

    #hb-{{ section.id }} .hb__img-wrap {
      max-width: 100% !important;
      margin-bottom: 0;
    }
  }
</style>

{% schema %}
{
  "name": "Hero Banner2 Text+Image",
  "tag": "section",
  "settings": [

    { "type": "header", "content": "━━ SECTION ━━" },
    { "type": "color",  "id": "bg_color",           "label": "Couleur de fond",           "default": "#b2e0d4" },
    { "type": "range",  "id": "bg_opacity",          "label": "Opacité fond (%)",          "min": 0, "max": 100, "step": 5, "unit": "%", "default": 100 },
    { "type": "range",  "id": "section_pad_v",       "label": "Padding vertical (px)",     "min": 0, "max": 120, "step": 4, "default": 48 },
    { "type": "range",  "id": "section_pad_h",       "label": "Padding horizontal (px)",   "min": 0, "max": 120, "step": 4, "default": 64 },
    { "type": "range",  "id": "section_height",      "label": "Hauteur min (px)",          "min": 200, "max": 900, "step": 20, "default": 460 },
    { "type": "range",  "id": "max_width",           "label": "Largeur max (px)",          "min": 800, "max": 1600, "step": 20, "default": 1400 },
    { "type": "range",  "id": "columns_gap",         "label": "Espace entre colonnes (px)","min": 0, "max": 120, "step": 4, "default": 32 },
    { "type": "range",  "id": "left_flex",           "label": "Ratio colonne gauche",      "min": 1, "max": 9, "step": 1, "default": 5,
      "info": "Ex: 5/5 → 50/50 · 6/4 → 60/40" },
    { "type": "range",  "id": "right_flex",          "label": "Ratio colonne droite",      "min": 1, "max": 9, "step": 1, "default": 5 },
    { "type": "range",  "id": "left_pad_bottom",     "label": "Padding bas colonne gauche (px)", "min": 0, "max": 120, "step": 4, "default": 48 },

    { "type": "header", "content": "━━ TITRE ━━" },
    { "type": "textarea","id": "heading",            "label": "Titre",                     "default": "1 sélection personnalisée de livres pour votre enfant." },
    { "type": "color",  "id": "heading_color",       "label": "Couleur",                   "default": "#111111" },
    { "type": "range",  "id": "heading_size",        "label": "Taille (px)",               "min": 18, "max": 80, "step": 2, "default": 54 },
    { "type": "select", "id": "heading_weight",      "label": "Graisse",                   "default": "800",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra-bold" },
        { "value": "900", "label": "Black" }
      ]
    },
    { "type": "range",  "id": "heading_lh",          "label": "Interligne (×10)",          "min": 10, "max": 20, "step": 1, "default": 12 },
    { "type": "range",  "id": "heading_mb",          "label": "Marge bas (px)",            "min": 0, "max": 80, "step": 4, "default": 28 },

    { "type": "header", "content": "━━ SOUS-TEXTE ━━" },
    { "type": "richtext","id": "subtext",            "label": "Texte",                     "default": "<p>Ils sont <strong>+20.000 parents</strong> à s'inspirer chaque mois de nos recommandations de lecture.</p>" },
    { "type": "color",  "id": "subtext_color",       "label": "Couleur",                   "default": "#222222" },
    { "type": "range",  "id": "subtext_size",        "label": "Taille (px)",               "min": 12, "max": 26, "step": 1, "default": 18 },
    { "type": "range",  "id": "subtext_lh",          "label": "Interligne (×10)",          "min": 10, "max": 22, "step": 1, "default": 16 },
    { "type": "range",  "id": "subtext_mb",          "label": "Marge bas (px)",            "min": 0, "max": 80, "step": 4, "default": 36 },

    { "type": "header", "content": "━━ BOUTON ━━" },
    { "type": "text",   "id": "btn_label",           "label": "Texte",                     "default": "Je me lance" },
    { "type": "url",    "id": "btn_url",             "label": "Lien" },
    { "type": "color",  "id": "btn_bg",              "label": "Fond",                      "default": "#ffffff" },
    { "type": "color",  "id": "btn_color",           "label": "Texte",                     "default": "#111111" },
    { "type": "color",  "id": "btn_border_color",    "label": "Bordure",                   "default": "#6ecfb5" },
    { "type": "range",  "id": "btn_border_width",    "label": "Épaisseur bordure (px)",    "min": 0, "max": 8, "step": 1, "default": 2 },
    { "type": "range",  "id": "btn_radius",          "label": "Arrondi (px)",              "min": 0, "max": 60, "step": 2, "default": 50 },
    { "type": "range",  "id": "btn_font_size",       "label": "Taille texte (px)",         "min": 12, "max": 22, "step": 1, "default": 16 },
    { "type": "select", "id": "btn_weight",          "label": "Graisse",                   "default": "600",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ]
    },
    { "type": "range",  "id": "btn_pad_v",           "label": "Padding vertical (px)",     "min": 6, "max": 40, "step": 2, "default": 18 },
    { "type": "range",  "id": "btn_pad_h",           "label": "Padding horizontal (px)",   "min": 12, "max": 120, "step": 4, "default": 56 },
    { "type": "range",  "id": "btn_min_width",       "label": "Largeur min (px)",          "min": 80, "max": 500, "step": 10, "default": 220 },

    { "type": "header", "content": "━━ IMAGE ━━" },
    { "type": "image_picker","id": "hero_image",     "label": "Image" },
    { "type": "range",  "id": "image_max_width",     "label": "Largeur max desktop (px)",  "min": 100, "max": 1000, "step": 20, "default": 620 },
    { "type": "range",  "id": "image_offset_y",      "label": "Débordement haut (px)",     "min": 0, "max": 200, "step": 4, "default": 0,
      "info": "Augmenter pour que l'image remonte au-dessus de la section." },

    { "type": "header", "content": "━━ MOBILE ━━" },
    { "type": "range",  "id": "mobile_breakpoint",   "label": "Breakpoint (px)",           "min": 480, "max": 1024, "step": 8, "default": 768 },
    { "type": "range",  "id": "mobile_pad_v",        "label": "Padding vertical (px)",     "min": 0, "max": 80, "step": 4, "default": 32 },
    { "type": "range",  "id": "mobile_pad_h",        "label": "Padding horizontal (px)",   "min": 0, "max": 60, "step": 4, "default": 24 },
    { "type": "range",  "id": "mobile_left_pb",      "label": "Espace texte → image (px)", "min": 0, "max": 80, "step": 4, "default": 24 },
    { "type": "range",  "id": "mobile_img_height",   "label": "Hauteur réservée image (px)", "min": 100, "max": 500, "step": 10, "default": 260,
      "info": "Espace réservé en bas de la section pour l'image." },
    { "type": "range",  "id": "mobile_img_width",    "label": "Largeur image mobile (%)",  "min": 30, "max": 90, "step": 5, "default": 60,
      "info": "L'image occupe ce % de la largeur, collée à droite." },
    { "type": "checkbox","id": "btn_full_mobile",    "label": "Bouton pleine largeur",     "default": true }

  ],
  "presets": [
    { "name": "Hero Banner — Texte + Image", "category": "Hero" }
  ]
}
{% endschema %}
